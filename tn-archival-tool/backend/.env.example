# Application
APP_NAME=TN Archival Tool
APP_ENV=development
DEBUG=true
API_PREFIX=/api

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://archival:archival@localhost:5432/tn_archival

# Redis (job queue — Week 2)
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=change-me-to-a-long-random-secret-key
ACCESS_TOKEN_EXPIRE_HOURS=8

# CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Evidence storage
EVIDENCE_STORAGE_PATH=../evidence
